# =============================================================================
# API de Ingestão — Variáveis de Ambiente (Exemplo)
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Substitua os valores marcados com "_change_me" antes de usar em produção
#   3. NUNCA commite o arquivo .env no controle de versão
# =============================================================================

# -----------------------------------------------------------------------------
# Redis — Cache de idempotência
# Formato: redis://<host>:<porta>
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# RabbitMQ — Message Broker AMQP
# Topologia: infrastructure/contracts/rabbitmq-topology.jsonc
# -----------------------------------------------------------------------------
RABBITMQ_USER=fleet_admin
RABBITMQ_PASS=fleet_rabbit_change_me
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# -----------------------------------------------------------------------------
# Porta da API de Ingestão (HTTP POST /api/v1/gps)
# -----------------------------------------------------------------------------
API_PORT=3000
