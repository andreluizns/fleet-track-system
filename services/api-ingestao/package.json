{
  "name": "api-ingestao",
  "version": "1.0.0",
  "description": "Fleet Track — API de Ingestão GPS (HTTP POST /api/v1/gps)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "@fastify/sensible": "^5.6.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "amqplib": "^0.10.4",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.6",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
