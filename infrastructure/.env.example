# =============================================================================
# Fleet Track — Variáveis de Ambiente (Exemplo)
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Substitua os valores marcados com "_change_me" antes de usar em produção
#   3. NUNCA commite o arquivo .env no controle de versão (ver .gitignore)
#
# Para Kubernetes/Produção: utilize Secrets do K8s ou Hashicorp Vault.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL / PostGIS — Credenciais do banco de dados geoespacial
# Imagem: postgis/postgis:16-3.4
# -----------------------------------------------------------------------------
POSTGRES_USER=fleet_user
POSTGRES_PASSWORD=fleet_pass_change_me
POSTGRES_DB=fleet_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis — Cache de idempotência e estado em tempo real
# Acessível APENAS via rede interna Docker (fleet_network)
# Formato: redis://<host>:<porta>
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# RabbitMQ — Message Broker AMQP
# Topologia de filas/exchanges: contracts/rabbitmq-topology.jsonc
# Provisionamento: scripts/setup-rabbitmq.sh
# -----------------------------------------------------------------------------
RABBITMQ_USER=fleet_admin
RABBITMQ_PASS=fleet_rabbit_change_me
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# -----------------------------------------------------------------------------
# Portas de Aplicação
# API_PORT   — API de Ingestão GPS (HTTP POST /api/v1/gps)
# WORKER_PORT — WebSocket Server (Socket.io → Frontend Next.js)
# -----------------------------------------------------------------------------
API_PORT=3000
WORKER_PORT=3001
